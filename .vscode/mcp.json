{
	"servers": {
		"github-mcp-dui14": {
			"url": "https://api.githubcopilot.com/mcp/",
			"type": "http"
		},
		"context7": {
			"url": "https://mcp.context7.com/mcp",
			"type": "http",
            "headers": {
                "CONTEXT7_API_KEY": "YOUR_CONTEXT7_API_KEY_HERE"
            }
        },
		"codegraph": {
			"command": "node",
			"args": ["node_modules/@colbymchenry/codegraph/dist/bin/codegraph.js", "serve", "--mcp"],
			"env": {
				"CODEGRAPH_ROOT_DIR": "${workspaceFolder}"
			}
		}
    },
	"inputs": []
}